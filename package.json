{
  "name": "api-debugger",
  "private": true,
  "version": "0.1.1",
  "description": "API Debugger - Browser-first API debugging tool",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start:agent": "cd apps/agent && npm start",
    "start:api": "cd apps/api && npm start",
    "start:ai": "cd apps/ai-service && npm start",
    "start:all": "npm run start:agent & npm run start:api & npm run start:ai",
    "test": "echo \"Run tests manually - see docs/TESTING.md\"",
    "lint": "echo \"No linter configured yet\""
  },
  "keywords": [
    "api",
    "debugger",
    "browser-extension",
    "api-testing",
    "developer-tools"
  ],
  "author": "",
  "license": "MIT"
}
